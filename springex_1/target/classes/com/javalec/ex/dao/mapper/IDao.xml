<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.javalec.ex.dao.IDao">	<!-- 인터페이스 경로 가져옴 --> <!-- 네임스페이스(Namespace)는 개체를 구분할 수 있는 범위를 나타내는 말 -->
	<select id="ContentDao" resultType="com.javalec.ex.dto.MemberDto">	<!-- resultType은 반환타입 -->
		SELECT * FROM members WHERE id = #{param1}
	</select>
	
	
</mapper>
